# ─── Supabase (cache persistente) ──────────────────────────────────────────
# Obtenha em: https://supabase.com → Project → Settings → API
# - SUPABASE_URL:  URL do projeto (ex.: https://xxxx.supabase.co)
# - SUPABASE_KEY:  service_role key (secreta! não comitar)
SUPABASE_URL=
SUPABASE_KEY=

# ─── TMDB (tradução + indexer) ─────────────────────────────────────────────
# Chave pessoal é opcional. Se não definir, o addon usa a chave pública.
# Obter em: https://www.themoviedb.org/settings/api
TMDB_KEY=

# ─── Real-Debrid (opcional — streaming direto HTTP) ────────────────────────
# Obtenha em: https://real-debrid.com/apitoken
# Sem esta chave, o addon entrega apenas magnets (funciona normalmente).
REALDEBRID_KEY=

# ─── Indexer ───────────────────────────────────────────────────────────────
# Quantos títulos por tipo (filme/série) indexar a cada execução.
INDEXER_LIMIT=50
